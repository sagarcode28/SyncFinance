{
  "name": "syncfinance-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "SyncFinance - Real-Time Collaborative Financial Planning Workspace",
  "workspaces": [
    ".",
    "server"
  ],
  "scripts": {
    "dev": "npm run dev:client",
    "dev:client": "vite",
    "dev:server": "cd server && npm run dev",
    "dev:all": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "build": "npm run build:client",
    "build:client": "vite build",
    "build:server": "cd server && npm run build",
    "build:all": "npm run build:client && npm run build:server",
    "start:server": "cd server && npm start",
    "install:all": "npm install && cd server && npm install",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:server": "cd server && npm run lint"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
